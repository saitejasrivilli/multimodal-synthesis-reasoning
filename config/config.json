{
  "data": {
    "reaction_images": 100,
    "pubchem_molecules": 1000,
    "synthesis_steps": 50,
    "train_val_split": 0.8
  },
  "vision": {
    "backbone": "resnet50",
    "pretrained": true,
    "image_size": 224,
    "freeze_backbone": false
  },
  "language": {
    "base_model": "meta-llama/Llama-2-7b-hf",
    "method": "lora",
    "lora_r": 16,
    "lora_alpha": 32,
    "lora_dropout": 0.05,
    "max_seq_length": 512
  },
  "fusion": {
    "method": "cross_attention",
    "hidden_dim": 768,
    "num_heads": 8,
    "dropout": 0.1
  },
  "training": {
    "epochs": 5,
    "batch_size": 4,
    "learning_rate": 1e-4,
    "warmup_steps": 100,
    "gradient_accumulation_steps": 2
  },
  "evaluation": {
    "metrics": ["synthesis_success_rate", "step_accuracy", "condition_prediction"],
    "test_molecules": 50
  }
}
